<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- File Provider extension. App extensions must be sandboxed. The App
	     Group is what the appex Info.plist's NSExtensionFileProviderDocumentGroup
	     points at; the entitlement must match a group the profile authorizes
	     (group.org.sockpuppet.wiki — note: ".wiki", see plans/signing.md). -->
	<key>com.apple.application-identifier</key>
	<string>KK7E9G89GW.org.sockpuppet.WikiFS.FileProvider</string>
	<key>com.apple.developer.team-identifier</key>
	<string>KK7E9G89GW</string>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.org.sockpuppet.wiki</string>
	</array>
	<!-- No get-task-allow: these profiles don't grant it (subset rule). -->
</dict>
</plist>
